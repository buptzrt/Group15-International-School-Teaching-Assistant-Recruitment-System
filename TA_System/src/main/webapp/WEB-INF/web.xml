    <session-config>
        <!-- 【重要】Session 超时时间设置为 30 分钟（单位：分钟） -->
        <session-timeout>30</session-timeout>
        <!-- 【关键修复】禁用 URL 重写和会话固定攻击防护
             原因：某些 servlet 容器（包括 Tomcat）在处理 multipart 请求时
             会进行会话固定，导致原有的 JSESSIONID 失效，创建新的 session
             这在我们的 file upload 场景中导致用户需要重新登录
        -->
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>
